---
// Hero: gradiente navy->teal, nombre, título, tagline, botones (CV, LinkedIn, GitHub)
import Icon from './Icon.astro';

const cvHref = '/documents/cv_alejandro_ruiz.pdf';
const githubHref = 'https://github.com/alejandroruizcastellano';
// TODO: sustituir por la URL real de LinkedIn antes del deploy final
const linkedinHref = '#';
---

<section
	id="inicio"
	class="relative overflow-hidden bg-[linear-gradient(135deg,#0B1D33_0%,#1A3A5C_60%,#0D6B5F_100%)] px-6 py-16 sm:px-10 sm:py-24"
>
	<!-- Círculos decorativos -->
	<div class="pointer-events-none absolute -top-16 -right-16 h-72 w-72 rounded-full bg-teal-400/[0.08]"></div>
	<div class="pointer-events-none absolute -bottom-24 left-10 h-80 w-80 rounded-full bg-teal-400/[0.08]"></div>

	<div class="relative mx-auto flex max-w-4xl flex-col items-center gap-8 text-center sm:flex-row sm:text-left">
		<div class="flex-1">
			<h1 class="text-3xl font-semibold text-white sm:text-4xl">Alejandro Ruiz Castellano</h1>
			<p class="mt-2 text-base text-teal-400 sm:text-lg">Data Analyst · Ingeniero Técnico Industrial</p>
			<p class="mt-4 max-w-xl text-sm leading-relaxed text-white/80 sm:text-base">
				¡Bienvenid@ a mi portfolio!
			</p>

			<div class="mt-6 flex flex-wrap justify-center gap-3 sm:justify-start">
				<a
					href={cvHref}
					class="flex h-10 items-center justify-center rounded-md border border-white/30 px-5 text-sm font-medium text-white transition-colors hover:border-teal-400 hover:text-teal-400"
				>
					Mi CV
				</a>
				<a
					href={linkedinHref}
					aria-label="LinkedIn"
					class="flex h-10 w-10 items-center justify-center rounded-md border border-white/30 text-white transition-colors hover:border-teal-400 hover:text-teal-400"
				>
					<Icon name="linkedin" class="h-5 w-5" />
				</a>
				<a
					href={githubHref}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="GitHub"
					class="flex h-10 w-10 items-center justify-center rounded-md border border-white/30 text-white transition-colors hover:border-teal-400 hover:text-teal-400"
				>
					<Icon name="github" class="h-5 w-5" />
				</a>
			</div>
		</div>

		<img
			src="/images/profile.png"
			alt="Alejandro Ruiz Castellano"
			class="h-[160px] w-[160px] flex-none rounded-full border border-white/30 object-cover object-top sm:h-[200px] sm:w-[200px]"
		/>
	</div>
</section>
