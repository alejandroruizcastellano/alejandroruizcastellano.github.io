---
// Tarjeta de proyecto: header con gradiente por categoría, título, descripción, tags, link GitHub
import type { Project } from '../data/projects';

interface Props extends Project {}

const { title, description, tags, github, category, icon } = Astro.props as Props;

const gradients: Record<Project['category'], string> = {
	ml: 'linear-gradient(135deg, #1A3A5C, #0D9488)',
	engineering: 'linear-gradient(135deg, #0B1D33, #2DD4BF)',
	analytics: 'linear-gradient(135deg, #0B1D33, #2DD4BF)',
};
---

<a
	href={github}
	target="_blank"
	rel="noopener noreferrer"
	class="group flex flex-col overflow-hidden rounded-xl border border-[0.5px] border-slate-200 bg-white transition-colors hover:border-teal-500"
>
	<div
		class="flex h-[90px] items-center justify-center"
		style={{ background: gradients[category] }}
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
			class="h-8 w-8 text-white/80"
		>
			{icon === 'chart-line' && (
				<path stroke-linecap="round" stroke-linejoin="round" d="M3 3v18h18M7 14l3-3 3 3 5-7" />
			)}
			{icon === 'users' && (
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M15 19.5a3 3 0 00-6 0M9 10.5a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5zM16.5 19.5c0-1.5-.5-2.7-1.34-3.51M16.5 10.5a2.25 2.25 0 100-4.5M3 19.5c.3-1.84 1.6-3 4-3s3.7 1.16 4 3"
				/>
			)}
			{icon === 'sun' && (
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M12 3v2.25M12 18.75V21M4.5 12H6.75M17.25 12H19.5M6.05 6.05l1.59 1.59M16.36 16.36l1.59 1.59M6.05 17.95l1.59-1.59M16.36 7.64l1.59-1.59M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
				/>
			)}
			{icon === 'cart' && (
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.435M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 1.873-4.59 2.282-6.75H5.106M7.5 14.25L5.106 5.25M9.75 18.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0zM18.75 18.75a.75.75 0 11-1.5 0 .75.75 0 011.5 0z"
				/>
			)}
			{icon === 'building' && (
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-4h6v4M9 11h1.5M9 14h1.5M13.5 11H15M13.5 14H15"
				/>
			)}
		</svg>
	</div>

	<div class="flex flex-1 flex-col gap-2 p-3">
		<h3 class="text-sm font-medium text-navy-800 sm:text-[15px]">{title}</h3>
		<p class="text-sm leading-relaxed text-slate-600">{description}</p>
		<div class="mt-auto flex flex-wrap gap-1.5 pt-2">
			{tags.map((tag) => (
				<span class="rounded-sm bg-teal-50 px-2 py-0.5 text-[10px] text-teal-600 sm:text-[11px]">
					{tag}
				</span>
			))}
		</div>
	</div>
</a>
