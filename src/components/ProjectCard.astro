---
import Icon from './Icon.astro';
import type { Project } from '../data/projects';

interface Props extends Project {}

const { title, description, tags, github, category, icon, summary } = Astro.props as Props;
const modalId = summary ? `modal-${github.split('/').pop()}` : null;

const gradients: Record<Project['category'], string> = {
	ml: 'linear-gradient(135deg, #1A3A5C, #0D9488)',
	engineering: 'linear-gradient(135deg, #0B1D33, #2DD4BF)',
	analytics: 'linear-gradient(135deg, #0B1D33, #2DD4BF)',
};
---

<div
	class="group flex flex-col overflow-hidden rounded-xl border border-[0.5px] border-slate-200 bg-white transition-colors hover:border-teal-500"
>
	<div
		class="relative h-[140px] overflow-hidden"
		style={{ background: gradients[category] }}
	>
		<div class="absolute top-2 right-2 z-10 flex gap-1.5">
			{modalId && (
				<button
					data-modal-trigger={modalId}
					class="flex h-7 w-7 items-center justify-center rounded-full bg-white/90 text-slate-700 shadow-sm transition-all hover:bg-white hover:text-slate-900 hover:shadow-md"
					aria-label="Ver resumen del proyecto"
				>
					<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
						<path d="M10 12.5a2.5 2.5 0 100-5 2.5 2.5 0 000 5z" />
						<path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 010-1.186A10.004 10.004 0 0110 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0110 17c-4.257 0-7.893-2.66-9.336-6.41zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
					</svg>
				</button>
			)}
			<a
				href={github}
				target="_blank"
				rel="noopener noreferrer"
				class="flex h-7 w-7 items-center justify-center rounded-full bg-white/90 text-slate-700 shadow-sm transition-all hover:bg-white hover:text-slate-900 hover:shadow-md"
				aria-label="Ver en GitHub"
			>
				<Icon name="github" class="h-4 w-4" />
			</a>
		</div>

		<svg
			viewBox="0 0 400 140"
			xmlns="http://www.w3.org/2000/svg"
			preserveAspectRatio="none"
			class="absolute inset-0 h-full w-full"
