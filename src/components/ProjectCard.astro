---
import Icon from './Icon.astro';
import type { Project } from '../data/projects';

interface Props extends Project {}

const { title, description, tags, github, category, icon } = Astro.props as Props;

const gradients: Record<Project['category'], string> = {
	ml: 'linear-gradient(135deg, #1A3A5C, #0D9488)',
	engineering: 'linear-gradient(135deg, #0B1D33, #2DD4BF)',
	analytics: 'linear-gradient(135deg, #0B1D33, #2DD4BF)',
};
---

<a
	href={github}
	target="_blank"
	rel="noopener noreferrer"
	class="group flex flex-col overflow-hidden rounded-xl border border-[0.5px] border-slate-200 bg-white transition-colors hover:border-teal-500"
>
	<div
		class="relative h-[140px] overflow-hidden"
		style={{ background: gradients[category] }}
	>
		<div class="absolute top-2 right-2 z-10 flex h-7 w-7 items-center justify-center rounded-full bg-white/15 text-white/80 transition-colors group-hover:bg-white/25 group-hover:text-white">
			<Icon name="github" class="h-4 w-4" />
		</div>

		<svg
			viewBox="0 0 400 140"
			xmlns="http://www.w3.org/2000/svg"
			preserveAspectRatio="none"
			class="absolute inset-0 h-full w-full"
		>
			{icon === 'chart-line' && (
				<g>
					<line x1="80" y1="10" x2="80" y2="130" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
					<line x1="160" y1="10" x2="160" y2="130" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
					<line x1="240" y1="10" x2="240" y2="130" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
					<line x1="320" y1="10" x2="320" y2="130" stroke="white" stroke-opacity="0.08" stroke-width="1"/>
					<line x1="10" y1="35" x2="390" y2="35" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
					<line x1="10" y1="70" x2="390" y2="70" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
					<line x1="10" y1="105" x2="390" y2="105" stroke="white" stroke-opacity="0.06" stroke-width="1"/>
					<polygon points="20,115 65,95 110,100 150,78 195,82 235,62 270,65 270,130 20,130" fill="white" fill-opacity="0.06"/>
					<polyline points="20,115 65,95 110,100 150,78 195,82 235,62 270,65" stroke="white" stroke-opacity="0.75" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
					<line x1="270" y1="12" x2="270" y2="130" stroke="white" stroke-opacity="0.25" stroke-width="1" stroke-dasharray="3,3"/>
					<polyline points="270,65 310,50 350,40 390,28" stroke="white" stroke-opacity="0.45" stroke-width="2" fill="none" stroke-dasharray="6,4" stroke-linecap="round"/>
					<circle cx="20" cy="115" r="3" fill="white" fill-opacity="0.6"/>
					<circle cx="65" cy="95" r="3" fill="white" fill-opacity="0.6"/>
					<circle cx="110" cy="100" r="3" fill="white" fill-opacity="0.6"/>
					<circle cx="150" cy="78" r="3" fill="white" fill-opacity="0.6"/>
					<circle cx="195" cy="82" r="3" fill="white" fill-opacity="0.6"/>
					<circle cx="235" cy="62" r="3" fill="white" fill-opacity="0.6"/>
					<circle cx="270" cy="65" r="4.5" fill="white" fill-opacity="0.85"/>
					<circle cx="310" cy="50" r="3" fill="white" fill-opacity="0.35"/>
					<circle cx="350" cy="40" r="3" fill="white" fill-opacity="0.35"/>
					<circle cx="390" cy="28" r="3" fill="white" fill-opacity="0.35"/>
				</g>
			)}
			{icon === 'users' && (
				<g>
					<line x1="35" y1="125" x2="385" y2="125" stroke="white" stroke-opacity="0.2" stroke-width="1"/>
					<line x1="35" y1="125" x2="35" y2="15" stroke="white" stroke-opacity="0.2" stroke-width="1"/>
					<path d="M 20,25 Q 200,65 390,130" stroke="white" stroke-opacity="0.2" stroke-width="1.5" fill="none" stroke-dasharray="6,4"/>
					<circle cx="310" cy="35" r="3.5" fill="white" fill-opacity="0.8"/>
					<circle cx="335" cy="28" r="3.5" fill="white" fill-opacity="0.8"/>
					<circle cx="355" cy="42" r="3.5" fill="white" fill-opacity="0.8"/>
					<circle cx="325" cy="55" r="3.5" fill="white" fill-opacity="0.8"/>
					<circle cx="350" cy="20" r="3.5" fill="white" fill-opacity="0.8"/>
					<circle cx="370" cy="35" r="3.5" fill="white" fill-opacity="0.8"/>
					<circle cx="350" cy="20" r="9" fill="none" stroke="white" stroke-opacity="0.45" stroke-width="1.5"/>
					<circle cx="190" cy="72" r="3.5" fill="white" fill-opacity="0.5"/>
					<circle cx="215" cy="80" r="3.5" fill="white" fill-opacity="0.5"/>
					<circle cx="170" cy="85" r="3.5" fill="white" fill-opacity="0.5"/>
					<circle cx="205" cy="62" r="3.5" fill="white" fill-opacity="0.5"/>
					<circle cx="230" cy="90" r="3.5" fill="white" fill-opacity="0.5"/>
					<circle cx="180" cy="65" r="3.5" fill="white" fill-opacity="0.5"/>
					<circle cx="75" cy="105" r="3.5" fill="white" fill-opacity="0.28"/>
					<circle cx="95" cy="112" r="3.5" fill="white" fill-opacity="0.28"/>
					<circle cx="55" cy="108" r="3.5" fill="white" fill-opacity="0.28"/>
					<circle cx="85" cy="98" r="3.5" fill="white" fill-opacity="0.28"/>
					<circle cx="110" cy="116" r="3.5" fill="white" fill-opacity="0.28"/>
					<circle cx="65" cy="118" r="3.5" fill="white" fill-opacity="0.28"/>
				</g>
			)}
			{icon === 'cart' && (
				<g>
					<rect x="15"  y="12" width="370" height="28" rx="3" fill="white" fill-opacity="0.55"/>
					<rect x="75"  y="56" width="250" height="28" rx="3" fill="white" fill-opacity="0.38"/>
					<rect x="145" y="100" width="110" height="28" rx="3" fill="white" fill-opacity="0.22"/>
					<text x="200" y="26" text-anchor="middle" dominant-baseline="central" font-size="11" font-family="system-ui,sans-serif" fill="#0B1D33" fill-opacity="0.65">Sessions</text>
					<text x="200" y="70" text-anchor="middle" dominant-baseline="central" font-size="11" font-family="system-ui,sans-serif" fill="#0B1D33" fill-opacity="0.65">Cart</text>
					<text x="200" y="114" text-anchor="middle" dominant-baseline="central" font-size="11" font-family="system-ui,sans-serif" fill="#0B1D33" fill-opacity="0.65">Purchase</text>
					<polygon points="196,42 204,42 200,50" fill="white" fill-opacity="0.45"/>
					<polygon points="196,86 204,86 200,94" fill="white" fill-opacity="0.32"/>
				</g>
			)}
			{icon === 'sun' && (
				<g>
					<path d="M 10,128 C 50,128 80,100 112,65 C 115,72 118,90 120,93 C 122,90 125,72 128,60 C 150,38 172,22 200,22 C 235,22 260,43 285,68 C 315,100 345,128 390,128 L 390,135 L 10,135 Z" fill="white" fill-opacity="0.07"/>
					<path d="M 10,128 C 50,128 80,100 112,65 C 115,72 118,90 120,93 C 122,90 125,72 128,60 C 150,38 172,22 200,22 C 235,22 260,43 285,68 C 315,100 345,128 390,128" stroke="white" stroke-opacity="0.65" stroke-width="2" fill="none" stroke-linecap="round"/>
					<line x1="120" y1="93" x2="120" y2="128" stroke="white" stroke-opacity="0.45" stroke-width="1.5" stroke-dasharray="4,3"/>
					<circle cx="120" cy="93" r="13" fill="none" stroke="white" stroke-opacity="0.88" stroke-width="2"/>
					<circle cx="120" cy="93" r="5" fill="white" fill-opacity="0.88"/>
					<line x1="10" y1="130" x2="390" y2="130" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
				</g>
			)}
			{icon === 'building' && (
				<g>
					<line x1="40" y1="12" x2="40" y2="122" stroke="white" stroke-opacity="0.22" stroke-width="1"/>
					<line x1="40" y1="122" x2="392" y2="122" stroke="white" stroke-opacity="0.22" stroke-width="1"/>
					<line x1="34" y1="38" x2="46" y2="38" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
					<line x1="34" y1="68" x2="46" y2="68" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
					<line x1="34" y1="98" x2="46" y2="98" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
					<line x1="130" y1="118" x2="130" y2="126" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
					<line x1="220" y1="118" x2="220" y2="126" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
					<line x1="310" y1="118" x2="310" y2="126" stroke="white" stroke-opacity="0.18" stroke-width="1"/>
					<line x1="52" y1="116" x2="378" y2="25" stroke="white" stroke-opacity="0.22" stroke-width="1.5" stroke-dasharray="5,3"/>
					<circle cx="238" cy="35" r="4"   fill="white" fill-opacity="0.82"/>
					<circle cx="260" cy="28" r="3.5" fill="white" fill-opacity="0.80"/>
					<circle cx="282" cy="40" r="4"   fill="white" fill-opacity="0.78"/>
					<circle cx="304" cy="25" r="3.5" fill="white" fill-opacity="0.76"/>
					<circle cx="318" cy="44" r="3.5" fill="white" fill-opacity="0.74"/>
					<circle cx="250" cy="50" r="3"   fill="white" fill-opacity="0.70"/>
					<circle cx="274" cy="54" r="3.5" fill="white" fill-opacity="0.72"/>
					<circle cx="158" cy="55" r="3.5" fill="white" fill-opacity="0.50"/>
					<circle cx="178" cy="63" r="3"   fill="white" fill-opacity="0.48"/>
					<circle cx="198" cy="52" r="3.5" fill="white" fill-opacity="0.52"/>
					<circle cx="218" cy="70" r="3"   fill="white" fill-opacity="0.46"/>
					<circle cx="172" cy="74" r="3.5" fill="white" fill-opacity="0.44"/>
					<circle cx="205" cy="80" r="3"   fill="white" fill-opacity="0.48"/>
					<circle cx="68"  cy="96" r="3.5" fill="white" fill-opacity="0.30"/>
					<circle cx="86"  cy="103" r="3"  fill="white" fill-opacity="0.27"/>
					<circle cx="104" cy="92" r="3.5" fill="white" fill-opacity="0.32"/>
					<circle cx="122" cy="108" r="3"  fill="white" fill-opacity="0.27"/>
					<circle cx="78"  cy="110" r="3"  fill="white" fill-opacity="0.25"/>
					<circle cx="112" cy="86" r="3.5" fill="white" fill-opacity="0.30"/>
					<circle cx="136" cy="100" r="3"  fill="white" fill-opacity="0.27"/>
					<circle cx="80" cy="20" r="4.5" fill="white" fill-opacity="0.82"/>
					<circle cx="80" cy="20" r="10"  fill="none" stroke="white" stroke-opacity="0.38" stroke-width="1.5"/>
					<circle cx="370" cy="48" r="4"  fill="white" fill-opacity="0.62"/>
					<circle cx="370" cy="48" r="9"  fill="none" stroke="white" stroke-opacity="0.28" stroke-width="1.5"/>
				</g>
			)}
		</svg>
	</div>

	<div class="flex flex-1 flex-col gap-2 p-3">
		<h3 class="text-sm font-medium text-navy-800 sm:text-[15px]">{title}</h3>
		<p class="text-sm leading-relaxed text-slate-600">{description}</p>
		<div class="mt-auto flex flex-wrap gap-1.5 pt-2">
			{tags.map((tag) => (
				<span class="rounded-sm bg-teal-50 px-2 py-0.5 text-[10px] text-teal-600 sm:text-[11px]">
					{tag}
				</span>
			))}
		</div>
	</div>
</a>
