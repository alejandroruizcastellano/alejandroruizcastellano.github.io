---
// Grid/flex de TechBadge
import TechBadge from './TechBadge.astro';
import { techStack } from '../data/tech';
---

<section id="tecnologias" class="mx-auto max-w-4xl px-6 py-1 sm:px-10 sm:py-3">
	<h2 class="mb-4 inline-block border-b-2 border-teal-500 text-lg font-medium text-navy-800 sm:text-xl">
		Skills
	</h2>

	<div class="grid grid-cols-2 gap-3 sm:grid-cols-5">
		{techStack.map((tech) => (
			<TechBadge name={tech.name} />
		))}
	</div>
</section>
