---
// Pill con icono + nombre de tecnología
interface Props {
	name: string;
}

const { name } = Astro.props;
---

<span class="flex items-center justify-center gap-2 rounded-full border border-slate-200 bg-slate-100 px-3 py-1.5 text-[11px] text-slate-600">
	<span class="h-1.5 w-1.5 rounded-full bg-teal-600"></span>
	{name}
</span>
